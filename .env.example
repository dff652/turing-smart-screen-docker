# Copy to .env before running docker compose.

# USB serial device used by most UART-based screens.
# On FnOS/NAS this is commonly /dev/ttyACM0. Check with:
#   ls -l /dev/ttyACM* /dev/ttyUSB*
TURING_SERIAL_DEVICE=/dev/ttyACM0

# Upstream release tag or commit SHA.
TURING_REF=3.10.0

# Optional: use a prebuilt image instead of the local image name.
# IMAGE=your-dockerhub-user/turing-smart-screen:latest

TZ=Asia/Shanghai
